#!/bin/bash
# =============================================================================
# SchoolCare v2 — Start Development Environment
# =============================================================================
# Starts all services and opens the project in Google Antigravity IDE.
#
# Prerequisites:
#   - Docker (for Postgres + Redis)
#   - Go 1.26+ with Air (hot reload): go install github.com/air-verse/air@latest
#   - Yarn 4+ (for frontend)
#   - Antigravity IDE CLI (agy)
#
# Usage:
#   start_schoolcare         # full startup
#   start_schoolcare --help  # show this message
# =============================================================================

set -euo pipefail

PROJECT_DIR="$HOME/Playbit/schoolcare-v2"
BACKEND_DIR="$PROJECT_DIR/backend"
FRONTEND_DIR="$PROJECT_DIR/frontend"

# ── Colors ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

info()  { echo -e "${CYAN}[INFO]${NC}  $*"; }
ok()    { echo -e "${GREEN}[OK]${NC}    $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC}  $*"; }
err()   { echo -e "${RED}[ERR]${NC}   $*" >&2; }
header(){ echo -e "\n${BLUE}━━━ $* ━━━${NC}"; }

# ── Help ────────────────────────────────────────────────────────────────────
if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  sed -n '3,18p' "$0"
  exit 0
fi

# ── Verify project exists ───────────────────────────────────────────────────
if [[ ! -d "$PROJECT_DIR" ]]; then
  err "Project directory not found: $PROJECT_DIR"
  exit 1
fi

# ── Ensure Postgres & Redis are running ────────────────────────────────────
header "Infrastructure"

start_infra() {
  info "Starting PostgreSQL & Redis via Docker Compose..."
  cd "$BACKEND_DIR"
  docker compose up -d postgres redis
  # Wait for both to be healthy
  info "Waiting for PostgreSQL to be ready..."
  until docker exec schoolcare-pg pg_isready -U schoolcare &>/dev/null; do sleep 1; done
  ok "PostgreSQL is ready"
  info "Waiting for Redis to be ready..."
  until docker exec schoolcare-redis redis-cli ping &>/dev/null; do sleep 1; done
  ok "Redis is ready"
}

PG_RUNNING=false
REDIS_RUNNING=false

# Check if shared containers are already running with correct credentials
if docker ps --format '{{.Names}}' | grep -q 'shared-postgres'; then
  ok "PostgreSQL already running (shared-postgres on :5432)"
  PG_RUNNING=true
fi
if docker ps --format '{{.Names}}' | grep -q 'shared-redis'; then
  ok "Redis already running (shared-redis on :6379)"
  REDIS_RUNNING=true
fi

# Check if schoolcare-specific containers are running
if docker ps --format '{{.Names}}' | grep -q 'schoolcare-pg'; then
  ok "PostgreSQL already running (schoolcare-pg)"
  PG_RUNNING=true
fi
if docker ps --format '{{.Names}}' | grep -q 'schoolcare-redis'; then
  ok "Redis already running (schoolcare-redis)"
  REDIS_RUNNING=true
fi

if ! $PG_RUNNING || ! $REDIS_RUNNING; then
  start_infra
else
  info "All infrastructure already running — skipping Docker startup"
fi

# ── Create backend .env if missing ──────────────────────────────────────────
header "Configuration"

ENV_FILE="$BACKEND_DIR/.env"
if [[ ! -f "$ENV_FILE" ]]; then
  info "Creating backend .env with development defaults..."
  cat > "$ENV_FILE" <<-EOF
APP_ENV=development
APP_PORT=8080
LOG_LEVEL=debug

DB_HOST=localhost
DB_PORT=5432
DB_USER=schoolcare
DB_PASSWORD=schoolcare
DB_NAME=schoolcare
DB_SSLMODE=disable

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET=local-dev-jwt-secret-minimum-32-chars!!
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

STORAGE_DRIVER=local
STORAGE_PATH=./uploads
EOF
  ok "Created $ENV_FILE"
else
  ok "Backend .env already exists"
fi

# ── Kill leftover processes on exit ─────────────────────────────────────────
BACKEND_PID=""
FRONTEND_PID=""

cleanup() {
  echo -e "\n${YELLOW}━━━ Shutting down... ━━━${NC}"
  if [[ -n "$FRONTEND_PID" ]] && kill -0 "$FRONTEND_PID" 2>/dev/null; then
    kill "$FRONTEND_PID" 2>/dev/null
    wait "$FRONTEND_PID" 2>/dev/null
    ok "Frontend stopped"
  fi
  if [[ -n "$BACKEND_PID" ]] && kill -0 "$BACKEND_PID" 2>/dev/null; then
    kill "$BACKEND_PID" 2>/dev/null
    wait "$BACKEND_PID" 2>/dev/null
    ok "Backend stopped"
  fi
  ok "All services stopped"
  exit 0
}

trap cleanup SIGINT SIGTERM

# ── Start backend ──────────────────────────────────────────────────────────
header "Backend API (Go — port 8080)"

cd "$BACKEND_DIR"

if command -v air &>/dev/null; then
  info "Starting backend with Air (hot reload)..."
  air &
  BACKEND_PID=$!
else
  info "Air not found — starting with 'go run' (no hot reload)"
  info "Install with: go install github.com/air-verse/air@latest"
  go run ./cmd/server &
  BACKEND_PID=$!
fi

# Wait for backend to be ready
sleep 2
for i in $(seq 1 30); do
  if curl -sf http://localhost:8080/readyz &>/dev/null; then
    ok "Backend API is running on http://localhost:8080"
    break
  fi
  if [[ $i -eq 30 ]]; then
    warn "Backend may still be starting (no ping response after 30s)"
    warn "Check logs at $BACKEND_DIR/.air.toml or run manually"
  fi
  sleep 1
done

# ── Start frontend ─────────────────────────────────────────────────────────
header "Frontend (Vite React — port 3000)"

cd "$FRONTEND_DIR"

if [[ ! -d node_modules ]]; then
  info "Installing frontend dependencies..."
  yarn install --frozen-lockfile 2>/dev/null || yarn install
  ok "Dependencies installed"
fi

info "Starting frontend dev server..."
yarn dev &
FRONTEND_PID=$!

sleep 3
ok "Frontend is running on http://localhost:3000"

# ── Open in Antigravity IDE ─────────────────────────────────────────────────
header "Antigravity IDE"

info "Opening project in Antigravity IDE..."

# Prefer agy CLI (lighter, terminal-friendly), fall back to desktop app
AGY="$HOME/.local/bin/agy"
ANTIGRAVITY="/usr/bin/antigravity"

if [[ -x "$AGY" ]]; then
  # Open the project directory with agy (adds to workspace)
  "$AGY" --add-dir "$PROJECT_DIR" --add-dir "$BACKEND_DIR" --add-dir "$FRONTEND_DIR" &
  ok "Project opened in Antigravity CLI (agy)"
elif [[ -x "$ANTIGRAVITY" ]]; then
  # Desktop app
  "$ANTIGRAVITY" "$PROJECT_DIR" &
  ok "Project opened in Antigravity IDE"
else
  warn "Antigravity IDE not found — skipping"
  warn "Download from: https://antigravity.google"
fi

# ── Summary ─────────────────────────────────────────────────────────────────
header "Development Environment"
echo -e "  ${GREEN}Frontend:${NC}  http://localhost:3000"
echo -e "  ${GREEN}Backend:${NC}   http://localhost:8080"
echo -e "  ${GREEN}API docs:${NC}  http://localhost:8080/swagger/index.html"
echo -e "  ${GREEN}Project:${NC}   $PROJECT_DIR"
echo ""
echo -e "  ${YELLOW}Press Ctrl+C to stop all services${NC}"
echo ""

# Wait for either process to exit
wait
