#!/usr/bin/env zsh
# =============================================================================
# SchoolCare v2 — Start Development Environment
# =============================================================================
# Starts all services in GNOME terminal tabs and opens Antigravity IDE.
#
# Prerequisites:
#   - Docker (for Postgres + Redis)
#   - Go 1.26+ with Air (hot reload): go install github.com/air-verse/air@latest
#   - Yarn 4+ (for frontend)
#   - Antigravity IDE (at /usr/local/bin/antigravity-ide)
#
# Usage:
#   start_schoolcare              # full startup
#   start_schoolcare --help       # show this message
#   start_schoolcare stop         # stop all services
#   start_schoolcare status       # show running services
# =============================================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'
ok()    { echo "${GREEN}✔${NC} $1"; }
fail()  { echo "${RED}✖${NC} $1"; }
info()  { echo "${CYAN}›${NC} $1"; }
warn()  { echo "${YELLOW}⚠${NC} $1"; }

BASE_DIR="$HOME/Playbit/schoolcare-v2"
BACKEND_DIR="$BASE_DIR/backend"
FRONTEND_DIR="$BASE_DIR/frontend"
INFRA_DIR="$BACKEND_DIR"
SHARED_INFRA_DIR="$HOME/Playbit/shared-infrastructure"

BACKEND_PORT=8080
FRONTEND_PORT=4000

LOGS_DIR="$HOME/.schoolcare/logs"
mkdir -p "$LOGS_DIR"

# ---- helpers ----
kill_port() {
  local port=$1 name=$2
  local pid
  pid=$(lsof -ti ":$port" 2>/dev/null)
  if [ -n "$pid" ]; then
    kill "$pid" 2>/dev/null && ok "Stopped $name (PID $pid)" || fail "Could not stop $name"
  else
    info "$name (port $port) not running"
  fi
}

check_deps() {
  local missing=false
  command -v docker >/dev/null 2>&1 || { fail "docker not found"; missing=true; }
  command -v yarn   >/dev/null 2>&1 || { fail "yarn not found";   missing=true; }
  command -v air    >/dev/null 2>&1 || warn "air not found (backend will not hot-reload)"
  $missing && { fail "Install missing dependencies and retry"; exit 1; }
}

# ---- start ----
cmd_start() {
  echo "${CYAN}═══════════════════════════════════════${NC}"
  echo "${CYAN}  SchoolCare — Start${NC}"
  echo "${CYAN}═══════════════════════════════════════${NC}"

  check_deps

  TABS=()

  # ── Infrastructure (Postgres + Redis) ──────────────────────────────────
  echo ""
  echo "${CYAN}━━━ Infrastructure ───────────────────${NC}"

  PG_RUNNING=false
  REDIS_RUNNING=false

  # Check shared containers first
  if docker ps --format '{{.Names}}' | grep -q 'shared-postgres'; then
    ok "PostgreSQL already running (shared-postgres on :5432)"
    PG_RUNNING=true
  fi
  if docker ps --format '{{.Names}}' | grep -q 'shared-redis'; then
    ok "Redis already running (shared-redis on :6379)"
    REDIS_RUNNING=true
  fi

  # Check schoolcare-specific containers
  if docker ps --format '{{.Names}}' | grep -q 'schoolcare-pg'; then
    ok "PostgreSQL already running (schoolcare-pg)"
    PG_RUNNING=true
  fi
  if docker ps --format '{{.Names}}' | grep -q 'schoolcare-redis'; then
    ok "Redis already running (schoolcare-redis)"
    REDIS_RUNNING=true
  fi

  if ! $PG_RUNNING || ! $REDIS_RUNNING; then
    info "Starting missing infrastructure services..."
    # Use shared infra docker-compose if it exists, else fall back to backend's
    local compose_dir="$SHARED_INFRA_DIR"
    [[ ! -f "$compose_dir/docker-compose.yml" ]] && compose_dir="$BACKEND_DIR"

    if ! $PG_RUNNING; then
      (cd "$compose_dir" && docker compose up -d postgres 2>/dev/null || docker compose -f "$BACKEND_DIR/docker-compose.yml" up -d postgres)
      info "Waiting for PostgreSQL..."
      until docker exec shared-postgres pg_isready -U postgres &>/dev/null || docker exec schoolcare-pg pg_isready -U schoolcare &>/dev/null; do sleep 1; done
      ok "PostgreSQL is ready"
    fi
    if ! $REDIS_RUNNING; then
      (cd "$compose_dir" && docker compose up -d redis 2>/dev/null || docker compose -f "$BACKEND_DIR/docker-compose.yml" up -d redis)
      info "Waiting for Redis..."
      until docker exec shared-redis redis-cli ping &>/dev/null || docker exec schoolcare-redis redis-cli ping &>/dev/null; do sleep 1; done
      ok "Redis is ready"
    fi
  else
    ok "All infrastructure already running"
  fi

  # ── Create backend .env if missing ─────────────────────────────────────
  local env_file="$BACKEND_DIR/.env"
  if [[ ! -f "$env_file" ]]; then
    info "Creating backend .env with development defaults..."
    cat > "$env_file" <<-EOF
APP_ENV=development
APP_PORT=8080
LOG_LEVEL=debug

DB_HOST=localhost
DB_PORT=5432
DB_USER=schoolcare
DB_PASSWORD=schoolcare
DB_NAME=schoolcare
DB_SSLMODE=disable

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET=local-dev-jwt-secret-minimum-32-chars!!
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

STORAGE_DRIVER=local
STORAGE_PATH=./uploads
EOF
    ok "Created $env_file"
  else
    ok "Backend .env already exists"
  fi

  # ── Backend tab ────────────────────────────────────────────────────────
  echo ""
  echo "${CYAN}━━━ Backend ──────────────────────────${NC}"

  if lsof -ti ":$BACKEND_PORT" >/dev/null 2>&1; then
    ok "Backend (port $BACKEND_PORT) already running. Skipping..."
  else
    local backend_cmd="air"
    command -v air >/dev/null 2>&1 || backend_cmd="go run ./cmd/server"
    TABS+=("--tab" "--title" "backend" "-e" "bash -c 'cd $BACKEND_DIR && $backend_cmd 2>&1 | tee $LOGS_DIR/backend.log'")
    ok "Backend queued (port $BACKEND_PORT)"
  fi

  # ── Frontend tab ───────────────────────────────────────────────────────
  echo ""
  echo "${CYAN}━━━ Frontend ─────────────────────────${NC}"

  if lsof -ti ":$FRONTEND_PORT" >/dev/null 2>&1; then
    ok "Frontend (port $FRONTEND_PORT) already running. Skipping..."
  else
    if [[ ! -d "$FRONTEND_DIR/node_modules" ]]; then
      info "Installing frontend dependencies..."
      (cd "$FRONTEND_DIR" && yarn install --frozen-lockfile 2>/dev/null || yarn install)
      ok "Dependencies installed"
    fi
    TABS+=("--tab" "--title" "frontend" "-e" "bash -c 'cd $FRONTEND_DIR && yarn dev 2>&1 | tee $LOGS_DIR/frontend.log'")
    ok "Frontend queued (port $FRONTEND_PORT)"
  fi

  # ── Open terminal tabs ─────────────────────────────────────────────────
  if [ ${#TABS[@]} -gt 0 ]; then
    echo ""
    gnome-terminal "${TABS[@]}" 2>/dev/null &
    ok "Services started in terminal tabs"
  fi

  # ── Open Antigravity IDE ────────────────────────────────────────────────
  echo ""
  echo "${CYAN}━━━ IDE ──────────────────────────────${NC}"

  local antigravity="/usr/local/bin/antigravity-ide"
  if [[ -x "$antigravity" ]]; then
    "$antigravity" "$BASE_DIR" &>/dev/null &
    ok "Opened project in Antigravity IDE"
  else
    warn "Antigravity IDE not found — skipping"
  fi

  # ── Open browser ──────────────────────────────────────────────────────────
  echo ""
  echo "${CYAN}━━━ Browser ──────────────────────────${NC}"

  local frontend_url="http://localhost:$FRONTEND_PORT"
  echo "Checking $frontend_url (timeout: 60s)..."
  local elapsed=0
  while ! curl -k -sSf --max-time 2 "$frontend_url" >/dev/null 2>&1; do
    printf "\rWaiting for frontend server... %2d sec elapsed " "$elapsed"
    sleep 1
    elapsed=$((elapsed + 1))
    [ "$elapsed" -ge 60 ] && break
  done
  printf "\n"

  if command -v firefox &>/dev/null; then
    firefox "$frontend_url" >/dev/null 2>&1 &
    ok "Opened frontend in Firefox"
  elif command -v xdg-open &>/dev/null; then
    xdg-open "$frontend_url" >/dev/null 2>&1 &
    ok "Opened frontend in default browser"
  else
    warn "No browser found — open manually: $frontend_url"
  fi

  # ── Summary ─────────────────────────────────────────────────────────────
  echo ""
  echo "${CYAN}═══════════════════════════════════════${NC}"
  echo "  ${GREEN}Frontend:${NC}  $frontend_url"
  echo "  ${GREEN}Backend:${NC}   http://localhost:$BACKEND_PORT"
  echo "  ${GREEN}API docs:${NC}  http://localhost:$BACKEND_PORT/swagger/index.html"
  echo ""
}

# ---- stop ----
cmd_stop() {
  echo "${CYAN}Stopping SchoolCare services...${NC}"
  kill_port $BACKEND_PORT "backend"
  kill_port $FRONTEND_PORT "frontend"

  if docker ps --format '{{.Names}}' | grep -q 'schoolcare-pg\|schoolcare-redis'; then
    info "Stopping schoolcare Docker services..."
    cd "$BACKEND_DIR" 2>/dev/null && docker compose down 2>/dev/null && ok "Docker services stopped"
  fi
}

# ---- status ----
cmd_status() {
  echo "${CYAN}SchoolCare Status${NC}"
  echo ""

  local any=false
  local pids

  pids=$(lsof -ti ":$BACKEND_PORT" 2>/dev/null)
  if [ -n "$pids" ]; then ok "Backend (port $BACKEND_PORT) — PID $pids"; any=true; else info "Backend (port $BACKEND_PORT) — stopped"; fi

  pids=$(lsof -ti ":$FRONTEND_PORT" 2>/dev/null)
  if [ -n "$pids" ]; then ok "Frontend (port $FRONTEND_PORT) — PID $pids"; any=true; else info "Frontend (port $FRONTEND_PORT) — stopped"; fi

  if docker ps --format '{{.Names}}' | grep -q 'schoolcare-pg'; then ok "PostgreSQL (schoolcare-pg)"; any=true; else info "PostgreSQL (schoolcare-pg) — stopped"; fi
  if docker ps --format '{{.Names}}' | grep -q 'schoolcare-redis'; then ok "Redis (schoolcare-redis)"; any=true; else info "Redis (schoolcare-redis) — stopped"; fi
  if docker ps --format '{{.Names}}' | grep -q 'shared-postgres'; then ok "PostgreSQL (shared-postgres)"; any=true; else info "PostgreSQL (shared-postgres) — stopped"; fi
  if docker ps --format '{{.Names}}' | grep -q 'shared-redis'; then ok "Redis (shared-redis)"; any=true; else info "Redis (shared-redis) — stopped"; fi

  echo ""
  [ "$any" = false ] && info "No services running"
}

# ---- help ----
cmd_help() {
  echo "${CYAN}SchoolCare${NC}"
  echo ""
  echo "Usage: start_schoolcare <command>"
  echo ""
  echo "Commands:"
  echo "  start                 Start services (default)"
  echo "  stop                  Stop all services"
  echo "  status                Show running services"
  echo "  help                  Show this help"
}

# ---- dispatch ----
CMD="${1:-start}"
shift 2>/dev/null || true

case "$CMD" in
  start|up)   cmd_start ;;
  stop|down)  cmd_stop ;;
  status|ps)  cmd_status ;;
  help|--help|-h) cmd_help ;;
  *)          fail "Unknown command '$CMD'. Use 'start_schoolcare help'."; exit 1 ;;
esac
